# ===========================================
# Benim Masalım - Environment Variables
# ===========================================
# SECURITY: Never commit .env with real values!
# Generate secrets with: openssl rand -hex 64

# App
APP_ENV=development        # development | staging | production
DEBUG=true
SECRET_KEY=generate-me-with-openssl-rand-hex-64
FRONTEND_URL=http://localhost:3000
BEHIND_PROXY=false
WEBHOOK_SECRET=generate-me-with-openssl-rand-hex-32

# Database
# Docker Compose: postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@postgres:5432/benimmasalim
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/benimmasalim
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Docker Compose DB credentials (no defaults in production!)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=benimmasalim

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Storage driver: "gcs" (production) or "local" (development without GCS credentials)
STORAGE_DRIVER=gcs
LOCAL_STORAGE_PATH=/app/media

# Google Cloud
GCP_PROJECT_ID=benimmasalim-dev
GCS_BUCKET_RAW=benimmasalim-raw-uploads
GCS_BUCKET_GENERATED=benimmasalim-generated-books
GCS_BUCKET_AUDIO=benimmasalim-audio-files
GCS_BUCKET_IMAGES=benimmasalim-images
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
# Or inline JSON (used in Cloud Run):
# GCS_CREDENTIALS_JSON={"type":"service_account",...}

# AI APIs
GEMINI_API_KEY=your-gemini-api-key
FAL_API_KEY=your-fal-ai-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Payment (Iyzico)
# Sandbox: https://sandbox-api.iyzipay.com
# Production: https://api.iyzipay.com
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Auth (JWT)
# PRODUCTION: must be 64+ chars! Generate: openssl rand -hex 64
JWT_SECRET_KEY=dev-only-jwt-secret-key-min-32-characters-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth (Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# KVKK
KVKK_RETENTION_DAYS=30
AUTO_DELETE_ENABLED=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-me-with-openssl-rand-hex-32

# Monitoring
SENTRY_DSN=
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_DRAFT=5
RATE_LIMIT_ORDER=10
RATE_LIMIT_LOGIN=5

# PgAdmin (development only, tools profile)
PGADMIN_EMAIL=admin@benimmasalim.com
PGADMIN_PASSWORD=change-me-strong-password
